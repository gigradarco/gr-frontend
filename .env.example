# Copy into `.env` for local development or set in Vercel.
# Never put secret API keys, Turso, Supabase service role, or Stripe secrets here.
# Frontend env values are public once used by browser code.
# The Worker (gr-backend) holds all real secrets; see gr-backend/.dev.vars.example + README.

VITE_APP_NAME=GigRadar

# API target: local | cloud (omit for legacy: only VITE_API_BASE_URL)
VITE_API_MODE=local
# Used when VITE_API_MODE=local. Omit this key (recommended) or use VITE_API_LOCAL_URL= for Vite proxy —
# same host as the UI (http://localhost:5173), which avoids CORS and OAuth cookie/host mismatches.
# Set only if you need to call the Worker directly, e.g. VITE_API_LOCAL_URL=http://127.0.0.1:8787
# VITE_API_LOCAL_URL=
# Used when VITE_API_MODE=cloud
VITE_API_CLOUD_URL=https://gr-backend-dev.gigradar.workers.dev

# Legacy (if VITE_API_MODE unset): empty = Vite proxy; else full Worker URL.
# VITE_API_BASE_URL=

# Discover event source:
# live = fetch real backend data
# demo = use frontend fixture data for UI debugging only
# auto = try live; demo fallback only works when VITE_DISCOVER_EVENTS_ALLOW_DEMO_FALLBACK=true
VITE_DISCOVER_EVENTS_SOURCE=live
# Keep false in production. Set true locally only when you intentionally want fixture fallback debugging.
VITE_DISCOVER_EVENTS_ALLOW_DEMO_FALLBACK=false

# Google Maps Embed API public browser key.
# Restrict in Google Cloud to HTTP referrers for our frontend domains and Maps Embed API only.
# Do not reuse this key for server-side Places, Geocoding, Directions, or other paid/secret APIs.
GOOGLE_MAPS_EMBED_KEY=

# Auth runs through gr-backend (`/api/auth/*`); Supabase keys stay on the server only.
# Google sign-in (local): add Supabase Redirect URLs for your API callback host, e.g.
#   http://localhost:5173/api/auth/callback  (Vite proxy)
#   http://127.0.0.1:8787/api/auth/callback  (VITE_API_LOCAL_URL direct)
# Leave AUTH_CALLBACK_ORIGIN unset in gr-backend/.dev.vars for local — see gr-backend/.dev.vars.example.

# OpenAI (server-side only; do not expose in frontend code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Optional: Vercel serverless proxy.
VITE_OPENAI_PROXY_URL=/api/openai-recommend

# ---------------------------------------------------------------------------
# Production (e.g. Vercel) — point the browser at the deployed Cloudflare Worker
# ---------------------------------------------------------------------------
# VITE_API_MODE=cloud
# VITE_API_CLOUD_URL=https://gr-backend-dev.gigradar.workers.dev
# Add the same Vercel URL(s) to gr-backend secrets as ALLOWED_ORIGINS (comma-separated origins only).
# Supabase → Authentication → Redirect URLs: include your Vercel origin and the Worker’s /api/auth/callback
#   if AUTH_CALLBACK_ORIGIN is set on the Worker (see gr-backend README).
